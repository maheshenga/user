APP_NAME=EasyAdmin8
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Shanghai
APP_URL=https://example.com

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=zh_CN
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=easyadmin8_laravel
DB_USERNAME=easyadmin_prod
DB_PASSWORD=change_me_to_a_strong_password
DB_PREFIX=ea8_
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_general_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CF_TURNSTILE_STATUS=true
CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=

DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_API_KEY=
DASHSCOPE_API_MODEL=qwen-plus

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
CACHE_PREFIX=easyadmin8_prod

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MODULE_SIGNING_ACTIVE_KEY_ID=
MODULE_SIGNING_KEYS={}
MODULE_SIGNING_KEY=
MODULE_WORKER_URL=
MODULE_WORKER_PROTOCOL_VERSION=1.0
MODULE_WORKER_ACTIVE_KEY_ID=
MODULE_WORKER_KEYS={}
MODULE_WORKER_TIMEOUT_SECONDS=10
MODULE_WORKER_CONNECT_TIMEOUT_SECONDS=3
MODULE_WORKER_MAX_RESPONSE_BYTES=1048576
MODULE_WORKER_CLOCK_SKEW_SECONDS=300
MODULE_WORKER_HEALTH_CACHE_SECONDS=30
MODULE_REGISTRATION_TICKET_KEY=
MODULE_LEGACY_CLIENT_ROUTES_ENABLED=true
MODULE_LEGACY_CLIENT_SUNSET="Sun, 31 Jan 2027 00:00:00 GMT"
MODULE_INTEGRITY_CACHE_SECONDS=60
MODULE_RETENTION_DAYS=90
MODULE_RETENTION_LIMIT=500

EASYADMIN.ADMIN_SYSTEM_LOG=true
EASYADMIN.ADMIN=admin
EASYADMIN.CAPTCHA=true
EASYADMIN.IS_DEMO=false
EASYADMIN.CDN=
EASYADMIN.EXAMPLE=false
EASYADMIN.IS_CSRF=true
EASYADMIN.STATIC_PATH=/static
EASYADMIN.OSS_STATIC_PREFIX=static_easyadmin
EASYADMIN.RATE_LIMITING_STATUS=true
